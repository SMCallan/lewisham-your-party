---
import Layout from '../layouts/Layout.astro';

const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));
const filteredPosts = allNews
    .filter((post: any) => post.frontmatter.category === 'Announcements')
    // Newsfeed: Always newest publish date first
    .sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Announcements - Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        <div class="max-w-4xl mx-auto mt-8 mb-20">
            {/* --- STANDARDIZED PAGE HEADER --- */}
            <div class="mb-10">
                <a href="/" class="inline-block mb-4 text-yp-red font-bold uppercase tracking-wider hover:underline">
                    &larr; Back to Home
                </a>
                <br />
                <h1 class="text-5xl md:text-7xl font-heading uppercase tracking-tighter inline-block border-b-8 border-yp-red pb-1">
                    Announcements
                </h1>
            </div>
            
            <div class="flex flex-col gap-8">
                {filteredPosts.length === 0 ? <p class="opacity-70 text-xl">No recent announcements.</p> : filteredPosts.map((post: any) => (
                    <article class="bg-white p-6 md:p-8 shadow-md border-l-8 border-yp-slate relative">
                        {post.frontmatter.featured_image && (
                            <img 
                                src={post.frontmatter.featured_image} 
                                alt="" 
                                class="w-full h-auto object-contain mb-6 shadow-sm mt-4"
                            />
                        )}
                        <div class="flex flex-wrap gap-4 text-sm font-bold text-gray-400 mb-2 tracking-widest uppercase mt-4">
                            <span>Published: {new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                        </div>
                        <h2 class="text-3xl font-bold text-yp-slate mb-4">{post.frontmatter.title}</h2>
                        <div class="prose prose-slate max-w-none"><post.default /></div>
                    </article>
                ))}
            </div>
        </div>
    </main>
</Layout>
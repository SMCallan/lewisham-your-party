---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Your Voice Has Been Heard - Lewisham Your Party"
    description="Confirmation page for Lewisham Your Party's anonymous suggestion box."
>
    <main class="bg-yp-cream text-yp-slate p-8 md:p-16 pt-0 md:pt-0">
        <div class="max-w-2xl mx-auto bg-yp-slate text-white p-8 md:p-12 shadow-xl text-center border-t-8 border-yp-red mb-20">
            <h1 class="text-5xl md:text-7xl font-heading uppercase tracking-tighter mb-4 text-yp-cream">
                Your Voice
                <span class="block text-yp-red">Has Been Heard</span>
            </h1>

            <div class="w-16 h-1 bg-yp-red mx-auto mb-6"></div>

            <p class="text-lg mb-8 opacity-90 leading-relaxed">
                Your submission has been sent to the local Lewisham organizing team. If you left contact details, someone may follow up. If you did not, your message will remain anonymous to us.
            </p>

            <div class="flex flex-col gap-4 sm:px-8">
                <a href="/your-voice" class="block w-full bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors cursor-pointer text-center">
                    Send Another Submission
                </a>

                <a href="/" class="block w-full bg-transparent border-2 border-white text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-white hover:text-yp-slate transition-colors cursor-pointer text-center">
                    Return To Lewisham Home
                </a>
            </div>
        </div>
    </main>
</Layout>

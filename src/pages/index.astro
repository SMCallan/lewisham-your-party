---
import Layout from '../layouts/Layout.astro';

// 1. Fetch all the markdown posts from our news folder
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));

// 2. Sort them by date (newest first)
const sortedNews = allNews.sort((a: any, b: any) => 
    new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);

// 3. Keep only the 3 most recent posts for the homepage feed
const latestUpdates = sortedNews.slice(0, 3);
---

<Layout title="Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        
        <div class="max-w-4xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-heading text-yp-slate uppercase tracking-tighter mb-4">
                Lewisham <span class="text-yp-red">Your Party</span>
            </h1>
            
            <div class="bg-yp-slate text-white p-8 md:p-12 mt-8 shadow-xl">
                <h2 class="text-3xl font-bold mb-4">We're building a new kind of political party.</h2>
                <p class="text-lg mb-8 opacity-90">
                    One that belongs to us. We organize local campaigning, fight against gentrification, and stand for homes for people, not profit.
                </p>
                
                <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 w-full max-w-xl">
                    <input type="hidden" name="access_key" value="a31ca5cd-cd04-4c1a-a13a-72fc67f7de4f" />
                    <input type="hidden" name="redirect" value="https://lewishamyourparty.org.uk/success" />
                    <input type="hidden" name="subject" value="New Member Signup - Lewisham YP" />
                    <input type="hidden" name="from_name" value="Lewisham YP Website" />

                    <div class="flex flex-col sm:flex-row gap-3">
                        <input 
                            type="email" 
                            placeholder="Enter your email" 
                            name="email" 
                            required
                            class="flex-grow p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full"
                        />
                        <button 
                            type="submit" 
                            class="bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors cursor-pointer whitespace-nowrap"
                        >
                            JOIN THE BRANCH
                        </button>
                    </div>

                    <div class="mt-4 flex items-start gap-3 text-sm opacity-90">
                        <input type="checkbox" id="consent" name="gdpr_consent" required class="mt-1 w-4 h-4 cursor-pointer" />
                        <label for="consent" class="cursor-pointer">I consent to receiving local updates from Lewisham YP. See our <a href="/privacy-notice" class="underline hover:text-yp-red">Privacy Notice</a>.</label>
                    </div>
                    <p class="text-xs opacity-60 mt-2 italic">*After clicking submit, you will be securely redirected to the national Your Party website.</p>
                </form>
            </div>
            
            <div class="mt-8 flex gap-4 flex-wrap font-bold text-sm uppercase">
                <a href="/events" class="bg-yp-red text-white px-3 py-1 hover:bg-white hover:text-yp-red border border-transparent hover:border-yp-red transition-colors">Events</a>
                <a href="/street-action" class="bg-yp-red text-white px-3 py-1 hover:bg-white hover:text-yp-red border border-transparent hover:border-yp-red transition-colors">Street Action</a>
                <a href="/announcements" class="bg-yp-red text-white px-3 py-1 hover:bg-white hover:text-yp-red border border-transparent hover:border-yp-red transition-colors">Announcements</a>
            </div>

            <div class="mt-20 mb-20">
                <h3 class="text-4xl font-heading uppercase border-b-4 border-yp-red inline-block mb-8">Latest Updates</h3>
                
                <div class="flex flex-col gap-6">
                    {latestUpdates.map((post: any) => (
                        <article class="bg-white p-6 shadow-md border-l-8 border-yp-red relative">
                            {post.frontmatter.category && (
                                <span class="absolute top-0 right-0 bg-yp-slate text-white text-xs font-bold px-3 py-1 uppercase">
                                    {post.frontmatter.category}
                                </span>
                            )}
                            
                            {post.frontmatter.featured_image && (
                                <img 
                                    src={post.frontmatter.featured_image} 
                                    alt="" 
                                    class="w-full h-64 object-cover mb-6 shadow-sm mt-4"
                                />
                            )}
                            <div class="flex flex-wrap gap-4 text-sm font-bold text-gray-400 mb-2 tracking-widest uppercase mt-4">
                                <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                {post.frontmatter.location && (
                                    <span class="text-yp-red flex items-center gap-1">
                                        📍 {post.frontmatter.location}
                                    </span>
                                )}
                            </div>
                            
                            <h4 class="text-2xl font-bold text-yp-slate mb-3">{post.frontmatter.title}</h4>
                            
                            <div class="prose prose-slate max-w-none">
                                <post.default />
                            </div>
                        </article>
                    ))}
                </div>
            </div>

        </div>
    </main>
</Layout>
---
import Layout from '../layouts/Layout.astro';

// 1. Fetch all the markdown posts from our news folder
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));

// 2. Sort them by date (newest first)
const sortedNews = allNews.sort((a: any, b: any) => 
    new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf()
);
---

<Layout title="Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        
        <div class="max-w-4xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-heading text-yp-slate uppercase tracking-tighter mb-4">
                Lewisham <span class="text-yp-red">Your Party</span>
            </h1>
            
            <div class="bg-yp-slate text-white p-8 md:p-12 mt-8 shadow-xl">
                <h2 class="text-3xl font-bold mb-4">We're building a new kind of political party.</h2>
                <p class="text-lg mb-8 opacity-90">
                    One that belongs to us. We organize local campaigning, fight against gentrification, and stand for homes for people, not profit.
                </p>
                
                <form method="POST" id="zcampaignOptinForm" action="https://zcv2-zcmp.maillist-manage.eu/weboptin.zc" target="_zcSignup" onsubmit="zcScptlessSubmit(this)" class="mt-6 w-full max-w-xl">
                    
                    <div class="flex flex-col sm:flex-row gap-3">
                        <input 
                            type="email" 
                            placeholder="Enter your email" 
                            name="CONTACT_EMAIL" 
                            id="EMBED_FORM_EMAIL_LABEL" 
                            required
                            class="flex-grow p-4 text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red"
                        />
                        <input 
                            type="submit" 
                            name="SIGNUP_SUBMIT_BUTTON" 
                            id="zcWebOptin" 
                            value="JOIN THE BRANCH" 
                            class="bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors cursor-pointer"
                        />
                    </div>

                    <div class="mt-4 flex items-start gap-3 text-sm opacity-90">
                        <input type="checkbox" id="consent" required class="mt-1 w-4 h-4 cursor-pointer" />
                        <label for="consent" class="cursor-pointer">I consent to receiving local updates from Lewisham YP.</label>
                    </div>
                    <p class="text-xs opacity-60 mt-2 italic">*After clicking submit, you will be securely redirected to the national Your Party website.</p>

                    <div class="hidden">
                        <input type="hidden" id="fieldBorder" value="">
                        <input type="hidden" id="submitType" name="submitType" value="optinCustomView">
                        <input type="hidden" id="emailReportId" name="emailReportId" value="">
                        <input type="hidden" id="formType" name="formType" value="QuickForm">
                        <input type="hidden" name="zx" id="cmpZuid" value="14aed49284">
                        <input type="hidden" name="zcvers" value="2.0">
                        <input type="hidden" name="oldListIds" id="allCheckedListIds" value="">
                        <input type="hidden" id="mode" name="mode" value="OptinCreateView">
                        <input type="hidden" id="zcld" name="zcld" value="13d452547cbe7936">
                        <input type="hidden" id="zctd" name="zctd" value="13d452547cbe7541">
                        <input type="hidden" id="document_domain" value="">
                        <input type="hidden" id="zc_Url" value="zcv2-zcmp.maillist-manage.eu">
                        <input type="hidden" id="new_optin_response_in" value="1">
                        <input type="hidden" id="duplicate_optin_response_in" value="1">
                        <input type="hidden" name="zc_trackCode" id="zc_trackCode" value="ZCFORMVIEW">
                        <input type="hidden" id="zc_formIx" name="zc_formIx" value="3z1b46e5de7361da99aefe6b99cbe608fa226402311df40b6c2d157170db47295b">
                        <input type="hidden" id="viewFrom" value="URL_ACTION">
                        <input type="hidden" id="scriptless" name="scriptless" value="yes">
                        <input type="hidden" id="zc_spmSubmit" name="zc_spmSubmit" value="ZCSPMSUBMIT">
                    </div>
                </form>
            </div>
            
            <div class="mt-8 flex gap-4 flex-wrap font-bold text-sm uppercase">
                <span class="bg-yp-red text-white px-3 py-1">Meeting</span>
                <span class="bg-yp-red text-white px-3 py-1">Street Action</span>
                <span class="bg-yp-red text-white px-3 py-1">Discussion</span>
            </div>

            <div class="mt-20">
                <h3 class="text-4xl font-heading uppercase border-b-4 border-yp-red inline-block mb-8">Latest Updates</h3>
                
                <div class="flex flex-col gap-6">
                    {sortedNews.map((post: any) => (
                        <article class="bg-white p-6 shadow-md border-l-8 border-yp-red">
                            {post.frontmatter.featured_image && (
                                <img 
                                    src={post.frontmatter.featured_image} 
                                    alt="" 
                                    class="w-full h-64 object-cover mb-6 shadow-sm"
                                />
                            )}
                            <p class="text-sm font-bold text-gray-400 mb-1 tracking-widest uppercase">
                                {new Date(post.frontmatter.date).toLocaleDateString('en-GB')}
                            </p>
                            <h4 class="text-2xl font-bold text-yp-slate mb-3">{post.frontmatter.title}</h4>
                            
                            <div class="prose prose-slate max-w-none">
                                <post.default />
                            </div>
                        </article>
                    ))}
                </div>
            </div>

        </div>
    </main>
</Layout>

<script is:inline>
	function zcScptlessSubmit(parentNode){
		if(parentNode.querySelector("#zc_spmSubmit")){parentNode.querySelector("#zc_spmSubmit").remove();}
        parentNode.submit();
	}
</script>
---
import Layout from '../layouts/Layout.astro';

// 1. Fetch all the markdown posts from our news folder
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));

// 2. Define "Today" (Midnight) for the Action Calendar
const today = new Date();
today.setHours(0, 0, 0, 0); 

// 3. BUILD FEED 1: Latest News (Events & Street Action ONLY, must be >= today, closest first)
const upcomingActions = allNews
    .filter((post: any) => 
        (post.frontmatter.category === 'Events' || post.frontmatter.category === 'Street Action') && 
        new Date(post.frontmatter.date) >= today
    )
    .sort((a: any, b: any) => new Date(a.frontmatter.date).valueOf() - new Date(b.frontmatter.date).valueOf())
    .slice(0, 3); // Grab top 3

// 4. BUILD FEED 2: Latest Announcements (Announcements ONLY, newest published first)
const latestAnnouncements = allNews
    .filter((post: any) => post.frontmatter.category === 'Announcements')
    .sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf())
    .slice(0, 3); // Grab top 3
---

<Layout title="Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        
        <div class="max-w-4xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-heading text-yp-slate uppercase tracking-tighter mb-4">
                Lewisham <span class="text-yp-red">Your Party</span>
            </h1>
            
            <div class="bg-yp-slate text-white p-8 md:p-12 mt-8 shadow-xl">
                <h2 class="text-3xl font-bold mb-4">We're building a new kind of political party.</h2>
                <p class="text-lg mb-8 opacity-90">
                    We are building a new kind of political party! One that belongs to the people of Lewisham. We are campaigning for high-quality housing standards, the protection of our essential public services, and a community built on international solidarity. From 'Sanctuary Borough' protections to universal free school meals, we are fighting for a local government that puts residents before profit.
                </p>
                
                <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 w-full max-w-xl">
                    <input type="hidden" name="access_key" value="a31ca5cd-cd04-4c1a-a13a-72fc67f7de4f" />
                    
                    <input type="hidden" name="redirect" value="https://lewishamyourparty.org.uk/success" />
                    <input type="hidden" name="subject" value="New Member Signup - Lewisham YP" />
                    <input type="hidden" name="from_name" value="Lewisham YP Website" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                        <input type="text" name="First Name" placeholder="First Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Last Name" placeholder="Last Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Postcode" placeholder="Postcode *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full uppercase" />
                        <input type="tel" name="Phone" placeholder="Phone (Optional)" class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3">
                        <input 
                            type="email" 
                            placeholder="Enter your email *" 
                            name="email" 
                            required
                            class="flex-grow p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full"
                        />
                        <button 
                            type="submit" 
                            class="bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors cursor-pointer whitespace-nowrap"
                        >
                            JOIN THE BRANCH
                        </button>
                    </div>

                    <div class="mt-4 flex items-start gap-3 text-sm opacity-90">
                        <input type="checkbox" id="consent" name="gdpr_consent" required class="mt-1 w-4 h-4 cursor-pointer" />
                        <label for="consent" class="cursor-pointer">I consent to receiving local updates from Lewisham YP. See our <a href="/privacy-notice" class="underline hover:text-yp-red">Privacy Notice</a>.</label>
                    </div>
                    <p class="text-xs opacity-60 mt-2 italic">*After clicking submit, you will be securely redirected to the national Your Party website.</p>
                </form>
            </div>
            
            <div class="mt-10 flex flex-col md:flex-row gap-6 justify-between items-start md:items-center">
                
                {/* --- BIG TEXT NAVIGATION LINKS --- */}
                <div class="flex gap-6 items-center">
                    <a href="/about" class="text-3xl font-heading uppercase text-yp-slate hover:text-yp-red transition-colors tracking-wide underline decoration-4 underline-offset-4 decoration-transparent hover:decoration-yp-red">
                        ABOUT & FAQS
                    </a>
                    
                    <a href="https://yourparty.uk" target="_blank" rel="noopener noreferrer" class="text-3xl font-heading uppercase text-yp-slate hover:text-yp-red transition-colors tracking-wide underline decoration-4 underline-offset-4 decoration-transparent hover:decoration-yp-red">
                        NATIONAL SITE
                    </a>
                </div>

                {/* --- FEED FILTER TAGS --- */}
                <div class="flex gap-3 flex-wrap font-bold text-sm uppercase">
                    <a href="/events" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors cursor-pointer">Events</a>
                    <a href="/street-action" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors cursor-pointer">Street Action</a>
                    <a href="/announcements" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors cursor-pointer">Announcements</a>
                    <a href="/campaigns" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors cursor-pointer">Campaigns</a>
                </div>
                
            </div>

            {/* --- DUAL FEED DASHBOARD --- */}
            <div class="mt-20 mb-20 grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-none items-start">
                
                {/* COLUMN 1: LATEST NEWS (Events & Street Action) */}
                <div>
                    <div class="mb-8">
                        <h3 class="text-3xl font-heading uppercase border-b-4 border-yp-red inline-block mb-1">Latest News</h3>
                        <p class="text-sm text-black font-bold uppercase tracking-wider">Events & Street Action</p>
                    </div>
                    
                    <div class="flex flex-col gap-6">
                        {upcomingActions.length > 0 ? upcomingActions.map((post: any) => {
                            // Dynamically set the link depending on the category
                            const categoryLink = post.frontmatter.category === 'Street Action' ? '/street-action' : '/events';
                            
                            return (
                                <article class="bg-white p-6 shadow-md border-l-8 border-yp-red relative">
                                    {post.frontmatter.category && (
                                        <a href={categoryLink} class="absolute top-0 right-0 bg-yp-red text-white text-xs font-bold px-3 py-1 uppercase hover:bg-yp-slate transition-colors">
                                            {post.frontmatter.category}
                                        </a>
                                    )}
                                    
                                    {post.frontmatter.featured_image && (
                                        <a href={categoryLink} class="block mt-4 mb-4">
                                            <img src={post.frontmatter.featured_image} alt="" class="w-full h-auto object-contain shadow-sm hover:opacity-90 transition-opacity" />
                                        </a>
                                    )}
                                    
                                    <div class="flex flex-wrap gap-4 text-xs font-bold text-gray-500 mb-2 tracking-widest uppercase mt-4">
                                        <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                        {post.frontmatter.location && (
                                            <span class="text-yp-red flex items-center gap-1">📍 {post.frontmatter.location}</span>
                                        )}
                                    </div>
                                    
                                    <a href={categoryLink} class="group">
                                        <h4 class="text-xl font-bold text-yp-slate mb-3 group-hover:text-yp-red transition-colors">{post.frontmatter.title}</h4>
                                    </a>
                                    
                                    {/* Unclamped prose so the whole text shows */}
                                    <div class="prose prose-sm prose-slate max-w-none">
                                        <post.default />
                                    </div>

                                    <a href={categoryLink} class="inline-block mt-6 text-sm font-bold text-yp-red hover:text-yp-slate uppercase tracking-wider transition-colors border-b-2 border-yp-red hover:border-yp-slate pb-1">
                                        Go to {post.frontmatter.category} page &rarr;
                                    </a>
                                </article>
                            )
                        }) : (
                            <p class="text-gray-500 italic">No upcoming actions scheduled right now. Check back soon!</p>
                        )}
                    </div>
                </div>

                {/* COLUMN 2: LATEST ANNOUNCEMENTS */}
                <div>
                    <div class="mb-8">
                        <h3 class="text-3xl font-heading uppercase border-b-4 border-yp-red inline-block mb-1">Announcements</h3>
                        {/* Invisible spacer so the headers line up perfectly across the two columns */}
                        <p class="text-sm text-transparent select-none uppercase tracking-wider hidden md:block">&nbsp;</p>
                    </div>

                    <div class="flex flex-col gap-6">
                        {latestAnnouncements.length > 0 ? latestAnnouncements.map((post: any) => (
                            <article class="bg-white p-6 shadow-md border-l-8 border-yp-slate relative">
                                {post.frontmatter.category && (
                                    <a href="/announcements" class="absolute top-0 right-0 bg-yp-slate text-white text-xs font-bold px-3 py-1 uppercase hover:bg-yp-red transition-colors">
                                        {post.frontmatter.category}
                                    </a>
                                )}
                                
                                {post.frontmatter.featured_image && (
                                    <a href="/announcements" class="block mt-4 mb-4">
                                        <img src={post.frontmatter.featured_image} alt="" class="w-full h-auto object-contain shadow-sm hover:opacity-90 transition-opacity" />
                                    </a>
                                )}
                                
                                <div class="flex flex-wrap gap-4 text-xs font-bold text-gray-500 mb-2 tracking-widest uppercase mt-4">
                                    <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                </div>
                                
                                <a href="/announcements" class="group">
                                    <h4 class="text-xl font-bold text-yp-slate mb-3 group-hover:text-yp-red transition-colors">{post.frontmatter.title}</h4>
                                </a>
                                
                                {/* Unclamped prose here too for consistency! */}
                                <div class="prose prose-sm prose-slate max-w-none">
                                    <post.default />
                                </div>

                                <a href="/announcements" class="inline-block mt-6 text-sm font-bold text-yp-slate hover:text-yp-red uppercase tracking-wider transition-colors border-b-2 border-yp-slate hover:border-yp-red pb-1">
                                    Go to Announcements page &rarr;
                                </a>
                            </article>
                        )) : (
                            <p class="text-gray-500 italic">No recent announcements.</p>
                        )}
                    </div>
                </div>

            </div>

        </div>
    </main>
</Layout>
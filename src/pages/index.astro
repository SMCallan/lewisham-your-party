---
import Layout from '../layouts/Layout.astro';

// 1. Fetch all the markdown posts from our news folder
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));

// 2. Define "Today" (Midnight) for the Action Calendar
const today = new Date();
today.setHours(0, 0, 0, 0); 

// 3. BUILD FEED 1: Latest News (Events & Street Action ONLY, must be >= today, closest first)
const upcomingActions = allNews
    .filter((post: any) => 
        (post.frontmatter.category === 'Events' || post.frontmatter.category === 'Street Action') && 
        new Date(post.frontmatter.date) >= today
    )
    .sort((a: any, b: any) => new Date(a.frontmatter.date).valueOf() - new Date(b.frontmatter.date).valueOf())
    .slice(0, 3); // Grab top 3

// 4. BUILD FEED 2: Latest Announcements (Announcements ONLY, newest published first)
const latestAnnouncements = allNews
    .filter((post: any) => post.frontmatter.category === 'Announcements')
    .sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf())
    .slice(0, 3); // Grab top 3

// 5. BROADSTREET DATE STAMP
const dateStamp = new Date().toLocaleDateString('en-GB', { 
    weekday: 'long', 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
}).toUpperCase();
---

<Layout title="Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16 pt-0 md:pt-0">
        
        <div class="max-w-6xl mx-auto">
            
            {/* NEWSPAPER FOLIO */}
            <div class="mb-12">
                <div class="flex flex-col md:flex-row justify-center md:justify-between items-center text-center gap-2 md:gap-0 border-y-4 border-yp-slate py-2 mb-8 font-bold text-[10px] md:text-xs uppercase tracking-widest text-yp-slate">
                    <span>SOLIDARITY!</span>
                    <span>{dateStamp}</span>
                    <span>LONDON BOROUGH OF LEWISHAM</span>
                </div>
                <div class="bg-yp-slate text-white p-8 md:p-12 shadow-xl">
                    <h2 class="text-3xl font-bold mb-4">We're building a new kind of political party.</h2>
                    <p class="text-lg mb-0 opacity-90">
                        We are building a new kind of political party! One that belongs to the people of Lewisham. We are campaigning for high-quality housing standards, the protection of our essential public services, and a community built on international solidarity. From 'Sanctuary Borough' protections to universal free school meals, we are fighting for a local government that puts residents before profit.
                    </p>
                </div>
            </div>

            {/* --- DUAL FEED DASHBOARD --- */}
            <div class="mt-20 mb-20 grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-none items-start">
                
                {/* COLUMN 1: LATEST NEWS (Events & Street Action) */}
                <div>
                    <div class="mb-8 min-h-[80px]">
                        <h3 class="text-3xl font-heading uppercase border-b-4 border-yp-red inline-block mb-1">Latest News</h3>
                        <p class="text-sm text-black font-bold uppercase tracking-wider">Events & Street Action</p>
                    </div>
                    
                    <div class="flex flex-col gap-6">
                        {upcomingActions.length > 0 ? upcomingActions.map((post: any) => {
                            // Dynamically set the link depending on the category
                            const categoryLink = post.frontmatter.category === 'Street Action' ? '/street-action' : '/events';
                            
                            return (
                                <article class="relative border-4 border-yp-slate bg-white shadow-[10px_10px_0_0_rgba(34,56,63,1)] transition-all duration-150 hover:translate-x-[10px] hover:translate-y-[10px] hover:shadow-none cursor-pointer p-6 flex flex-col h-full">
                                    {post.frontmatter.category && (
                                        <a href={categoryLink} class="absolute -top-4 -right-2 z-10 px-3 py-1 bg-yp-red text-white font-black uppercase rotate-2 tracking-widest text-sm border-none">
                                            {post.frontmatter.category}
                                        </a>
                                    )}
                                    
                                    <div class="flex flex-wrap gap-4 mb-4 mt-2">
                                        <span class="bg-yp-slate text-yp-cream px-2 py-1 font-bold text-sm tracking-widest">
                                            {new Date(post.frontmatter.date).toLocaleDateString('en-GB')}
                                        </span>
                                        {post.frontmatter.location && (
                                            <span class="text-yp-red font-bold text-sm uppercase flex items-center gap-1">📍 {post.frontmatter.location}</span>
                                        )}
                                    </div>
                                    
                                    <a href={categoryLink} class="group">
                                        <h4 class="text-xl font-bold uppercase tracking-widest leading-tight text-yp-slate mb-4 group-hover:text-yp-red transition-colors">{post.frontmatter.title}</h4>
                                    </a>
                                    
                                    <p class="text-base md:text-lg font-medium leading-relaxed text-yp-slate mb-2 opacity-90 flex-grow">
                                        {post.frontmatter.synopsis}
                                    </p>

                                    <div class="mt-auto">
                                        <a href={categoryLink} class="font-black text-yp-slate uppercase tracking-widest hover:underline decoration-4 underline-offset-4 block">
                                            VIEW DETAILS ➔
                                        </a>
                                    </div>
                                </article>
                            )
                        }) : (
                            <p class="text-gray-500 italic">No upcoming actions scheduled right now. Check back soon!</p>
                        )}
                    </div>
                </div>

                {/* COLUMN 2: LATEST ANNOUNCEMENTS */}
                <div>
                    <div class="mb-8 min-h-[80px]">
                        <h3 class="text-3xl font-heading uppercase border-b-4 border-yp-red inline-block mb-1">Announcements</h3>
                    </div>

                    <div class="flex flex-col gap-6">
                        {latestAnnouncements.length > 0 ? latestAnnouncements.map((post: any) => (
                            <article class="relative border-4 border-yp-slate bg-white shadow-[10px_10px_0_0_rgba(34,56,63,1)] transition-all duration-150 hover:translate-x-[10px] hover:translate-y-[10px] hover:shadow-none cursor-pointer p-6 flex flex-col h-full">
                                {post.frontmatter.category && (
                                    <a href="/announcements" class="absolute -top-4 -right-2 z-10 px-3 py-1 bg-yp-red text-white font-black uppercase rotate-2 tracking-widest text-sm border-none">
                                        {post.frontmatter.category}
                                    </a>
                                )}
                                
                                <div class="flex flex-wrap gap-4 mb-4 mt-2">
                                    <span class="bg-yp-slate text-yp-cream px-2 py-1 font-bold text-sm tracking-widest">
                                        {new Date(post.frontmatter.date).toLocaleDateString('en-GB')}
                                    </span>
                                </div>
                                
                                <a href="/announcements" class="group">
                                    <h4 class="text-xl font-bold text-yp-slate uppercase tracking-widest leading-tight mb-4 group-hover:text-yp-red transition-colors">{post.frontmatter.title}</h4>
                                </a>
                                
                                <p class="text-base md:text-lg font-medium leading-relaxed text-yp-slate mb-2 opacity-90 flex-grow">
                                    {post.frontmatter.synopsis}
                                </p>

                                <div class="mt-auto">
                                    <a href="/announcements" class="font-black text-yp-slate uppercase tracking-widest hover:underline decoration-4 underline-offset-4 block">
                                        VIEW DETAILS ➔
                                    </a>
                                </div>
                            </article>
                        )) : (
                            <p class="text-gray-500 italic">No recent announcements.</p>
                        )}
                    </div>
                </div>

            </div>

            {/* --- SMART SIGNUP FORM (MOVED TO BOTTOM) --- */}
            <div id="join-mailing-list" class="bg-yp-slate text-white p-8 md:p-12 mt-20 mb-20 shadow-xl scroll-mt-10">
                <h2 class="text-3xl font-bold mb-4">Join our Mailing List</h2>
                <p class="text-lg mb-8 opacity-90">
                    Stay updated with our latest campaigns, events, and community action in Lewisham.
                </p>

                <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 w-full max-w-xl" id="signup-form">
                    <input type="hidden" name="access_key" value="a31ca5cd-cd04-4c1a-a13a-72fc67f7de4f" />
                    
                    {/* The redirect value here will be changed by the script below if they click "Yes" */}
                    <input type="hidden" name="redirect" id="form-redirect" value="https://lewishamyourparty.org.uk/success" />
                    <input type="hidden" name="subject" value="New Member Signup - Lewisham YP" />
                    <input type="hidden" name="from_name" value="Lewisham YP Website" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                        <input type="text" name="First Name" placeholder="First Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Last Name" placeholder="Last Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Postcode" placeholder="Postcode (Optional)" class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="tel" name="Phone" placeholder="Phone (Optional)" class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3">
                        <input 
                            type="email" 
                            placeholder="Enter your email *" 
                            name="email" 
                            required
                            class="flex-grow p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full"
                        />
                        <button 
                            type="submit" 
                            class="bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors cursor-pointer whitespace-nowrap"
                        >
                            JOIN THE BRANCH
                        </button>
                    </div>

                    {/* --- MEMBER CHECK (CUSTOM TOGGLES) --- */}
                    <div class="mt-6 mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-t border-white/20 pt-5">
                        <p class="text-sm font-bold opacity-90">Are you already a national member?</p>
                        
                        <div class="flex gap-2">
                            <label class="relative cursor-pointer group">
                                {/* 'sr-only' hides the default circle, 'peer' lets us style the span below it */}
                                <input type="radio" name="Already National Member" value="Yes" class="member-toggle sr-only peer" />
                                <span class="block px-4 py-2 bg-white/10 text-xs font-bold uppercase tracking-wider text-white peer-checked:bg-yp-red peer-checked:text-white hover:bg-white/20 transition-colors">
                                    Yes, I am
                                </span>
                            </label>
                            
                            <label class="relative cursor-pointer group">
                                <input type="radio" name="Already National Member" value="No" class="member-toggle sr-only peer" checked />
                                <span class="block px-4 py-2 bg-white/10 text-xs font-bold uppercase tracking-wider text-white peer-checked:bg-yp-red peer-checked:text-white hover:bg-white/20 transition-colors">
                                    No, not yet
                                </span>
                            </label>
                        </div>
                    </div>

                    <div class="mt-4 flex items-start gap-3 text-sm opacity-90">
                        <input type="checkbox" id="consent" name="gdpr_consent" required class="mt-1 w-4 h-4 cursor-pointer" />
                        <label for="consent" class="cursor-pointer">I consent to receiving local updates from Lewisham YP. See our <a href="/privacy-notice" class="underline hover:text-yp-red">Privacy Notice</a>.</label>
                    </div>
                    <p class="text-xs opacity-60 mt-2 italic">*After clicking submit, you will be securely redirected to the appropriate confirmation page.</p>
                </form>

                {/* --- ASTRO CLIENT SCRIPT FOR DYNAMIC REDIRECT --- */}
                <script>
                    const radios = document.querySelectorAll('.member-toggle');
                    const redirectInput = document.getElementById('form-redirect') as HTMLInputElement;

                    radios.forEach(radio => {
                        radio.addEventListener('change', (e) => {
                            const target = e.target as HTMLInputElement;
                            if (target.value === 'Yes') {
                                // If they are a member, send them to the local-only thank you page
                                redirectInput.value = "https://lewishamyourparty.org.uk/success-local";
                            } else {
                                // If they are NOT a member, send them to the page that tells them to join the national party
                                redirectInput.value = "https://lewishamyourparty.org.uk/success";
                            }
                        });
                    });
                </script>
            </div>

        </div>
    </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';

// 1. Fetch all the markdown posts from our news folder
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));

const today = new Date();
today.setHours(0, 0, 0, 0); 

// 2. BUILD FEEDS
const upcomingActions = allNews
    .filter((post: any) => 
        (post.frontmatter.category === 'Events' || post.frontmatter.category === 'Street Action') && 
        new Date(post.frontmatter.date) >= today
    )
    .sort((a: any, b: any) => new Date(a.frontmatter.date).valueOf() - new Date(b.frontmatter.date).valueOf())
    .slice(0, 3);

const latestAnnouncements = allNews
    .filter((post: any) => post.frontmatter.category === 'Announcements')
    .sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf())
    .slice(0, 3);
---

<Layout title="Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        
        <div class="max-w-4xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-heading text-yp-slate uppercase tracking-tighter mb-4">
                Lewisham <span class="text-yp-red">Your Party</span>
            </h1>
            
            <div class="bg-yp-slate text-white p-8 md:p-12 mt-8 shadow-xl">
                <h2 class="text-3xl font-bold mb-4">We're building a new kind of political party.</h2>
                <p class="text-lg mb-8 opacity-90 leading-relaxed">
                    One that belongs to us. We organize to protect our public services, fight for radical housing justice, and stand in international solidarity. From 'Sanctuary Borough' protections to free school meals, we are fighting for a Lewisham that puts people before profit.
                </p>
                
                <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 w-full max-w-xl">
                    <input type="hidden" name="access_key" value="a31ca5cd-cd04-4c1a-a13a-72fc67f7de4f" />
                    <input type="hidden" name="redirect" value="https://lewishamyourparty.org.uk/success" />
                    <input type="hidden" name="subject" value="New Member Signup - Lewisham YP" />

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
                        <input type="text" name="First Name" placeholder="First Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Last Name" placeholder="Last Name *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <input type="text" name="Postcode" placeholder="Postcode *" required class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full uppercase" />
                        <input type="tel" name="Phone" placeholder="Phone (Optional)" class="p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3">
                        <input type="email" name="email" placeholder="Enter your email *" required class="flex-grow p-4 bg-white text-yp-slate font-sans focus:outline-none focus:ring-2 focus:ring-yp-red w-full" />
                        <button type="submit" class="bg-yp-red text-white font-bold py-4 px-6 uppercase tracking-wider hover:bg-red-700 transition-colors">JOIN THE BRANCH</button>
                    </div>

                    <div class="mt-4 flex items-start gap-3 text-sm opacity-90">
                        <input type="checkbox" id="consent" name="gdpr_consent" required class="mt-1 w-4 h-4" />
                        <label for="consent">I consent to receiving local updates from Lewisham YP. See our <a href="/privacy-notice" class="underline">Privacy Notice</a>.</label>
                    </div>
                </form>
            </div>

            {/* --- NEW: THE FIVE PILLARS SECTION --- */}
            <div class="mt-16 mb-20">
                <h2 class="text-3xl font-heading uppercase border-b-8 border-yp-red inline-block mb-8">What We Stand For</h2>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                    {['Housing', 'Education', 'No Cuts', 'Anti-Racism', 'Palestine'].map((pillar) => (
                        <a href="/campaigns" class="bg-yp-slate text-white p-4 text-center font-bold uppercase text-xs tracking-tighter hover:bg-yp-red transition-all transform hover:-translate-y-1">
                            {pillar}
                        </a>
                    ))}
                </div>
            </div>
            
            <div class="mt-10 flex flex-col md:flex-row gap-6 justify-between items-start md:items-center">
                <div class="flex gap-6 items-center">
                    <a href="/about" class="text-3xl font-heading uppercase text-yp-slate hover:text-yp-red transition-colors underline decoration-4 underline-offset-4 decoration-transparent hover:decoration-yp-red">ABOUT & FAQS</a>
                    <a href="https://yourparty.uk" target="_blank" class="text-3xl font-heading uppercase text-yp-slate hover:text-yp-red transition-colors underline decoration-4 underline-offset-4 decoration-transparent hover:decoration-yp-red">NATIONAL SITE</a>
                </div>

                <div class="flex gap-3 flex-wrap font-bold text-sm uppercase">
                    <a href="/events" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors">Events</a>
                    <a href="/street-action" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors">Street Action</a>
                    <a href="/announcements" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors">Announcements</a>
                    <a href="/campaigns" class="bg-yp-red text-white px-3 py-1.5 hover:bg-yp-slate transition-colors">Campaigns</a>
                </div>
            </div>

            {/* FEED SECTION REMAINS SAME BELOW... */}
            <div class="mt-20 mb-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                {/* ... (Previous Feed Logic) ... */}
            </div>
        </div>
    </main>
</Layout>
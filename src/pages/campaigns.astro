---
import Layout from '../layouts/Layout.astro';

const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }));
const campaignsPosts = allNews
    .filter((post: any) => post.frontmatter.category === 'Campaigns')
    .sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Campaigns - Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        <div class="max-w-4xl mx-auto mb-20">
            
            {/* --- STANDARDIZED PAGE HEADER --- */}
            <div class="mb-10">
                <a href="/" class="inline-block mb-4 text-yp-red font-bold uppercase tracking-wider hover:underline">
                    &larr; Back to Home
                </a>
                <br />
                <h1 class="text-5xl md:text-7xl font-heading uppercase tracking-tighter inline-block border-b-8 border-yp-red pb-1">
                    Campaigns
                </h1>
            </div>
            
            <div class="flex flex-col gap-8">
                {campaignsPosts.length === 0 ? (
                    <p class="text-xl opacity-80">No campaigns announced yet. Check back soon!</p>
                ) : (
                    campaignsPosts.map((post: any) => (
                        <article class="bg-white p-6 md:p-8 shadow-md border-l-8 border-yp-red relative">
                            
                            {/* THE IMAGE FIX */}
                            {post.frontmatter.featured_image && (
                                <img 
                                    src={post.frontmatter.featured_image} 
                                    alt="" 
                                    class="w-full h-64 md:h-96 object-cover mb-6 shadow-sm"
                                />
                            )}
                            
                            <div class="flex flex-wrap gap-4 text-sm font-bold text-gray-400 mb-2 tracking-widest uppercase mt-4">
                                <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                {post.frontmatter.location && (
                                    <span class="text-yp-red flex items-center gap-1">📍 {post.frontmatter.location}</span>
                                )}
                            </div>
                            
                            <h2 class="text-3xl font-bold text-yp-slate mb-4">{post.frontmatter.title}</h2>
                            
                            {/* THE TYPOGRAPHY PROSE FIX */}
                            <div class="prose prose-slate max-w-none">
                                <post.default />
                            </div>
                        </article>
                    ))
                )}
            </div>
        </div>
    </main>
</Layout>

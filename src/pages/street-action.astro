---
import Layout from '../layouts/Layout.astro';

// 1. Fetch posts and filter ONLY for "Street Action"
const allNews = Object.values(import.meta.glob('../content/news/*.md', { eager: true }))
    .filter((post: any) => post.frontmatter.category === 'Street Action');

// 2. Define Date Boundaries
const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const tomorrow = new Date(today);
tomorrow.setDate(tomorrow.getDate() + 1);

// 3. Bucket the posts
const presentEvents = allNews.filter((post: any) => {
    const postDate = new Date(post.frontmatter.date);
    return postDate >= today && postDate < tomorrow;
});
const upcomingEvents = allNews.filter((post: any) => {
    const postDate = new Date(post.frontmatter.date);
    return postDate >= tomorrow;
});
const legacyEvents = allNews.filter((post: any) => {
    const postDate = new Date(post.frontmatter.date);
    return postDate < today;
});

// 4. Sort the buckets
upcomingEvents.sort((a: any, b: any) => new Date(a.frontmatter.date).valueOf() - new Date(b.frontmatter.date).valueOf());
legacyEvents.sort((a: any, b: any) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Street Action - Lewisham Your Party">
    <main class="min-h-screen bg-yp-cream text-yp-slate p-8 md:p-16">
        <div class="max-w-4xl mx-auto mt-8">
            <div class="mb-10">
                <a href="/" class="inline-block mb-4 text-yp-red font-bold uppercase tracking-wider hover:underline">&larr; Back to Home</a>
                <br />
                <h1 class="text-5xl md:text-7xl font-heading uppercase tracking-tighter inline-block border-b-8 border-yp-red pb-1">Street Action</h1>
            </div>

            <div class="mt-12 mb-20 flex flex-col gap-16">
                
                {allNews.length === 0 && <p class="opacity-70">No street actions logged yet.</p>}

                {/* --- TODAY BUCKET --- */}
                {presentEvents.length > 0 && (
                    <section>
                        <h3 class="text-3xl font-heading uppercase inline-block mb-8 bg-yp-red text-white px-4 py-2 animate-pulse rounded-sm shadow-md">Happening Today</h3>
                        <div class="flex flex-col gap-6">
                            {presentEvents.map((post: any) => (
                                <article class="bg-white p-6 md:p-8 shadow-lg border-l-8 border-yp-red border-t-4 border-t-yp-red relative">
                                    {post.frontmatter.featured_image && <img src={post.frontmatter.featured_image} alt="" class="w-full h-auto object-contain mb-6 shadow-sm" />}
                                    <div class="flex flex-wrap gap-4 text-sm font-bold text-gray-400 mb-2 tracking-widest uppercase">
                                        <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                        {post.frontmatter.location && <span class="text-yp-red flex items-center gap-1">📍 {post.frontmatter.location}</span>}
                                    </div>
                                    <h2 class="text-3xl font-bold text-yp-slate mb-4">{post.frontmatter.title}</h2>
                                    <div class="prose prose-slate max-w-none"><post.default /></div>
                                </article>
                            ))}
                        </div>
                    </section>
                )}

                {/* --- UPCOMING BUCKET --- */}
                {upcomingEvents.length > 0 && (
                    <section>
                        <div class="flex flex-col gap-6">
                            {upcomingEvents.map((post: any) => (
                                <article class="bg-white p-6 shadow-md border-l-8 border-yp-red relative">
                                    {post.frontmatter.featured_image && <img src={post.frontmatter.featured_image} alt="" class="w-full h-auto object-contain mb-6 shadow-sm" />}
                                    <div class="flex flex-wrap gap-4 text-sm font-bold text-gray-400 mb-2 tracking-widest uppercase">
                                        <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                        {post.frontmatter.location && <span class="text-yp-red flex items-center gap-1">📍 {post.frontmatter.location}</span>}
                                    </div>
                                    <h2 class="text-2xl font-bold text-yp-slate mb-3">{post.frontmatter.title}</h2>
                                    <div class="prose prose-slate max-w-none"><post.default /></div>
                                </article>
                            ))}
                        </div>
                    </section>
                )}

                {/* --- LEGACY / PAST BUCKET --- */}
                {legacyEvents.length > 0 && (
                    <section class="opacity-80">
                        <h3 class="text-3xl font-heading uppercase border-b-4 border-gray-400 text-gray-500 inline-block mb-8 mt-12">Past Actions</h3>
                        <div class="flex flex-col gap-6">
                            {legacyEvents.map((post: any) => (
                                <article class="bg-gray-50 p-6 shadow-sm border-l-8 border-gray-300 relative">
                                    {post.frontmatter.featured_image && <img src={post.frontmatter.featured_image} alt="" class="w-full h-auto object-contain mb-4 opacity-90 grayscale-[20%]" />}
                                    <div class="flex flex-wrap gap-4 text-xs font-bold text-gray-400 mb-2 tracking-widest uppercase mt-2">
                                        <span>{new Date(post.frontmatter.date).toLocaleDateString('en-GB')}</span>
                                        {post.frontmatter.location && <span class="flex items-center gap-1">📍 {post.frontmatter.location}</span>}
                                    </div>
                                    <h2 class="text-xl font-bold text-gray-600 mb-3">{post.frontmatter.title}</h2>
                                    <div class="prose prose-sm prose-slate max-w-none line-clamp-4"><post.default /></div>
                                </article>
                            ))}
                        </div>
                    </section>
                )}

            </div>
        </div>
    </main>
</Layout>
---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/Your_Party_logo.svg" />
        <meta name="generator" content={Astro.generator} />

        <title>Lewisham Your Party | Community Power in SE6 & SE13</title>
        <meta name="description" content="The official Lewisham branch of Your Party. We fight for homes for people, not profit, and organize local action across Catford, Lewisham, and Ladywell." />
        <meta name="keywords" content="Lewisham Your Party, Lewisham Politics, Catford Campaign, SE13 social justice, London grassroots politics" />

        <meta property="og:title" content="Lewisham Your Party" />
        <meta property="og:description" content="Building a new kind of political party in Lewisham. Join the movement." />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://lewishamyourparty.org.uk" />
        <meta property="og:image" content="/YPLOGO.png" />
    </head>
    
    <body class="bg-yp-cream flex flex-col min-h-screen">
        
        <div class="flex-grow">
            <slot />
        </div>

        <footer class="bg-yp-slate text-yp-cream py-16 border-t-8 border-yp-red mt-auto">
            <div class="max-w-4xl mx-auto px-8 md:px-16 flex flex-col md:flex-row justify-between items-start gap-12">
                
                {/* --- LEFT COLUMN: CONTACT & BRANDING --- */}
                <div class="flex flex-col gap-8 max-w-md">
                    <div class="text-sm opacity-90">
                        <p class="mb-1 font-bold">Published & Promoted by Lewisham Your Party.</p>
                        <p class="mb-6">Election Agent Nick Long, 41 Medusa Road, Catford SE6 4JW</p>
                    </div>

                    {/* VERTICAL EMAIL LIST */}
                    <div class="flex flex-col gap-4 font-bold text-xs md:text-sm tracking-widest border-l-4 border-yp-red pl-6 py-2">
                        <a href="mailto:hello@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">HELLO@LEWISHAMYOURPARTY.ORG.UK</a>
                        <a href="mailto:press@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">PRESS@LEWISHAMYOURPARTY.ORG.UK</a>
                        <a href="mailto:volunteer@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">VOLUNTEER@LEWISHAMYOURPARTY.ORG.UK</a>
                    </div>
                    
                    {/* INSTAGRAM */}
                    <div class="pt-2">
                        <a 
                            href="https://www.instagram.com/your_party_lewisham?igsh=bHVyY3ByYXpoanZ0" 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            class="inline-block hover:scale-110 transition-transform"
                            aria-label="Follow Lewisham Your Party on Instagram"
                        >
                            <img src="/instagram-cream.svg" alt="Instagram" class="w-8 h-8" />
                        </a>
                    </div>
                </div>

                {/* --- RIGHT COLUMN: NAVIGATION & LEGAL --- */}
                <div class="flex flex-col gap-8 md:text-right">
                    <div class="flex flex-col gap-3 font-heading uppercase text-sm tracking-wider">
                        <a href="/about" class="hover:text-yp-red transition-colors">About & FAQs</a>
                        <a href="/privacy-notice" class="hover:text-yp-red transition-colors">Privacy Policy</a>
                        <a href="/cookie-policy" class="hover:text-yp-red transition-colors">Cookie Policy</a>
                        <a href="/terms-of-service" class="hover:text-yp-red transition-colors">Terms of Service</a>
                    </div>
                </div>

            </div>
        </footer>

    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/Your_Party_logo.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>Lewisham YP</title>
    </head>
    <body class="bg-yp-cream flex flex-col min-h-screen">
        
        <div class="flex-grow">
            <slot />
        </div>

        <footer class="bg-yp-slate text-yp-cream py-12 border-t-8 border-yp-red mt-auto">
            <div class="max-w-4xl mx-auto px-8 md:px-16 flex flex-col md:flex-row justify-between items-start gap-8">
                
                {/* --- LEFT COLUMN: IMPRINT --- */}
                <div class="text-sm opacity-90 max-w-lg">
                    <p class="mb-1 font-bold">Published & Promoted by Lewisham Your Party.</p>
                    <p>Election Agent Nick Long, 41 Medusa Road, Catford SE6 4JW</p>
                </div>

                {/* --- RIGHT COLUMN: LEGAL & SOCIAL --- */}
                <div class="flex flex-col gap-6">
                    
                    {/* Legal Links */}
                    <div class="flex flex-col gap-3 font-heading uppercase text-sm tracking-wider">
                        <a href="/privacy-notice" class="hover:text-yp-red transition-colors">Privacy Policy</a>
                        <a href="/cookie-policy" class="hover:text-yp-red transition-colors">Cookie Policy</a>
                        <a href="/terms-of-service" class="hover:text-yp-red transition-colors">Terms of Service</a>
                    </div>
                    
                    {/* Instagram Icon */}
                    <div>
                        <a 
                            href="https://www.instagram.com/your_party_lewisham?igsh=bHVyY3ByYXpoanZ0" 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            class="inline-block hover:opacity-75 transition-opacity"
                            aria-label="Follow Lewisham Your Party on Instagram"
                        >
                            <img src="/instagram-cream.svg" alt="Instagram" class="w-8 h-8" />
                        </a>
                    </div>

                </div>

            </div>
        </footer>

    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
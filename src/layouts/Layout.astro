---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/Your_Party_logo.svg" />
        <link rel="icon" type="image/png" href="/YPLOGO.png" />
        <link rel="apple-touch-icon" href="/YPLOGO.png" />
        <meta name="generator" content={Astro.generator} />

        <title>Lewisham Your Party | Community Power</title>
        <meta name="description" content="The official Lewisham branch of Your Party. We fight for homes for people, not profit, and organize local action across the London Borough of Lewisham." />
        <meta name="keywords" content="Lewisham Your Party, Lewisham Politics, Catford Campaign, SE13 social justice, London grassroots politics" />

        <meta property="og:title" content="Lewisham Your Party" />
        <meta property="og:description" content="Building a new kind of political party in Lewisham. Join the movement." />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://lewishamyourparty.org.uk" />
        <meta property="og:image" content="https://lewishamyourparty.org.uk/YPLOGO.png" />
    </head>
    
    <body class="bg-yp-cream flex flex-col min-h-screen">
        
        <header class="pt-8 md:pt-16 pb-0">
            <div class="max-w-6xl mx-auto px-8 md:px-16">
                <a href="/" class="block hover:opacity-90 transition-opacity">
                    <h1 class="text-6xl md:text-7xl lg:text-8xl font-heading text-yp-slate uppercase tracking-tighter mb-4 leading-none">
                        Lewisham <span class="text-yp-red">Your Party</span>
                    </h1>
                </a>

                {/* --- UNIFIED NAVIGATION MENU --- */}
                <nav class="mt-8 mb-8 border-4 border-yp-slate shadow-[5px_5px_0_0_rgba(34,56,63,1)] md:shadow-[10px_10px_0_0_rgba(34,56,63,1)] overflow-hidden">
                    {/* ROW 1: PRIMARY LINKS */}
                    <div class="grid grid-cols-1 md:grid-cols-3 divide-y-4 md:divide-y-0 md:divide-x-4 divide-yp-slate border-b-4 border-yp-slate bg-white">
                        <a href="/about" class="p-5 text-center font-heading text-2xl md:text-3xl uppercase text-yp-slate hover:bg-yp-red hover:text-white transition-all">
                            WHO WE ARE
                        </a>
                        <a href="/#join-mailing-list" class="p-5 text-center font-heading text-2xl md:text-3xl uppercase text-yp-slate hover:bg-yp-red hover:text-white transition-all">
                            STAY UPDATED
                        </a>
                        <a href="https://yourparty.uk" target="_blank" rel="noopener noreferrer" class="p-5 text-center font-heading text-2xl md:text-3xl uppercase text-yp-slate hover:bg-yp-red hover:text-white transition-all">
                            NATIONAL SITE
                        </a>
                    </div>

                    {/* ROW 2: CATEGORY FILTERS */}
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-[4px] md:gap-0 md:divide-x-4 divide-yp-slate bg-yp-slate">
                        <a href="/events" class="p-4 bg-yp-red text-center font-bold uppercase tracking-widest text-xs md:text-sm text-white hover:bg-yp-slate transition-all">
                            Events
                        </a>
                        <a href="/street-action" class="p-4 bg-yp-red text-center font-bold uppercase tracking-widest text-xs md:text-sm text-white hover:bg-yp-slate transition-all">
                            Street Action
                        </a>
                        <a href="/announcements" class="p-4 bg-yp-red text-center font-bold uppercase tracking-widest text-xs md:text-sm text-white hover:bg-yp-slate transition-all">
                            Announcements
                        </a>
                        <a href="/campaigns" class="p-4 bg-yp-red text-center font-bold uppercase tracking-widest text-xs md:text-sm text-white hover:bg-yp-slate transition-all">
                            Campaigns
                        </a>
                    </div>
                </nav>
            </div>
        </header>

        <div class="flex-grow">
            <slot />
        </div>

        <footer class="bg-yp-slate text-yp-cream py-16 border-t-8 border-yp-red mt-auto">
            <div class="max-w-4xl mx-auto px-8 md:px-16 flex flex-col md:flex-row justify-between items-start gap-12">
                
                {/* --- LEFT COLUMN: CONTACT & BRANDING --- */}
                <div class="flex flex-col gap-8 max-w-md">
                    <div class="text-sm opacity-90">
                        <p class="mb-1 font-bold">Published & Promoted by Lewisham Your Party.</p>
                        <p class="mb-6">Endorsed by Lewisham Your Party</p>
                    </div>

                    {/* VERTICAL EMAIL LIST */}
                    <div class="flex flex-col gap-4 font-bold text-xs md:text-sm tracking-widest border-l-4 border-yp-red pl-6 py-2">
                        <a href="mailto:hello@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">HELLO@LEWISHAMYOURPARTY.ORG.UK</a>
                        <a href="mailto:press@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">PRESS@LEWISHAMYOURPARTY.ORG.UK</a>
                        <a href="mailto:volunteer@lewishamyourparty.org.uk" class="hover:text-yp-red transition-colors">VOLUNTEER@LEWISHAMYOURPARTY.ORG.UK</a>
                    </div>
                    
                    {/* INSTAGRAM */}
                    <div class="pt-2">
                        <a 
                            href="https://www.instagram.com/your_party_lewisham?igsh=bHVyY3ByYXpoanZ0" 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            class="inline-block hover:scale-110 transition-transform"
                            aria-label="Follow Lewisham Your Party on Instagram"
                        >
                            <img src="/instagram-cream.svg" alt="Instagram" class="w-8 h-8" />
                        </a>
                    </div>
                </div>

                {/* --- RIGHT COLUMN: NAVIGATION & LEGAL --- */}
                <div class="flex flex-col gap-8 md:text-right">
                    <div class="flex flex-col gap-3 font-heading uppercase text-sm tracking-wider">
                        <a href="/about" class="hover:text-yp-red transition-colors">Who We Are</a>
                        <a href="/privacy-notice" class="hover:text-yp-red transition-colors">Privacy Policy</a>
                        <a href="/cookie-policy" class="hover:text-yp-red transition-colors">Cookie Policy</a>
                        <a href="/terms-of-service" class="hover:text-yp-red transition-colors">Terms of Service</a>
                    </div>
                </div>

            </div>
        </footer>

    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>